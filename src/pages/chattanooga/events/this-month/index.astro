---
import BaseHead from '../../../../components/Head/BaseHead.astro';
import Nav from '../../../../components/Nav.astro';
import EventsNav from '../../../../components/EventsNav.astro';
import Card from '../../../../components/Card.astro';
import Footer from '../../../../components/Footer/Footer.astro';

const title = 'This Month in Chattanooga';
const seoDescription = 'Events happening this month in Chattanooga, TN.';

let allPosts = (await Astro.glob('../*.mdx')).filter(
  (post) => post.frontmatter.published !== false
);

let allPostsIncludingMultipleDates = [];

allPosts.forEach((p) => {
  const baseData = { ...p.frontmatter, url: p.url };
  if (baseData.eventDates) {
    baseData.eventDates.forEach((date) => {
      allPostsIncludingMultipleDates.push({ ...baseData, pubDate: date, url: `${baseData.url}?date=${date}` });
    });
  } else {
    allPostsIncludingMultipleDates.push(baseData);
  }
});

const today = new Date();
today.setHours(0, 0, 0, 0);
const firstDayOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
const lastDayOfMonth = new Date(today.getFullYear(), today.getMonth() + 1, 0);
lastDayOfMonth.setHours(23, 59, 59, 999);

allPostsIncludingMultipleDates = allPostsIncludingMultipleDates
  .filter(({ pubDate }) => {
    const d = new Date(pubDate);
    return d >= today && d >= firstDayOfMonth && d <= lastDayOfMonth;
  })
  .sort((a, b) => new Date(a.pubDate) - new Date(b.pubDate));
---

<html lang="en">
<head>
  <BaseHead title={title} description={seoDescription} />
</head>
<body class="text-black font-body leading-normal personality-casual">
  <Nav />
  <main>
    <article class="w-full px-4 md:px-8 lg:px-16 mt-8 pb-4">
      <header class="pt-10">
        <h1 class="font-jakarta font-bold text-5xl md:text-6xl leading-[1.2]">
          This Month in <span class="text-customGreen1">Chattanooga</span><span class="text-customGreen1">.</span>
        </h1>
        <p class="text-gray-600 text-3xl mt-3 mb-6">Events happening in Chattanooga this month</p>
      </header>
      <EventsNav active="this-month" />
      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-8 py-8" data-test="articles-section">
        {allPostsIncludingMultipleDates.map(p => (
          <div class="col-span-1"><Card post={p} /></div>
        ))}
        {allPostsIncludingMultipleDates.length === 0 && (
          <p class="col-span-3 text-xl text-gray-500">No events this month — check back soon.</p>
        )}
      </section>
    </article>
  </main>
  <Footer />
</body>
</html>
