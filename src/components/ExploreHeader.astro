---
interface Props {
  /** Font weight for the heading: bold (home) or medium (guides/editorials) */
  weight?: 'bold' | 'medium';
}

const { weight = 'bold' } = Astro.props;
const fontClass = weight === 'medium' ? 'font-medium' : 'font-bold';
---

<header class="pt-10 content">
  <h1 class={`font-jakarta ${fontClass} text-5xl md:text-6xl leading-[1.2]`}>
    <slot />
  </h1>
</header>
